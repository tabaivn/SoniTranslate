YOUR_HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxx
GRADIO_SERVER_NAME=0.0.0.0
GRADIO_SERVER_PORT=7860
NO_PROXY=localhost,127.0.0.1,::1
no_proxy=localhost,127.0.0.1,::1
SONITR_DEVICE=cuda
SONITR_LANGUAGE=vietnamese
SONITR_THEME=soft
SONITR_ALLOW_HF_THEME=0
SONITR_VERBOSITY=info
SONITR_CPU_MODE=0
SONITR_PUBLIC_URL=0
HF_HOME=/workspace/.cache/huggingface
PIP_CACHE_DIR=/workspace/.cache/pip
SONITR_DEPS_VERSION=4
# Dependencies are baked into the image at build time — pod starts in seconds.
# Rebuild image after requirements change: DOCKER_BUILDKIT=1 docker build -t sonitranslate .
# Set SONITR_RUNTIME_INSTALL=1 only for dev without rebuilding the image.
# Rebuild image after code changes (required for preprocessor fix):
#   DOCKER_BUILDKIT=1 docker build --no-cache -t your-registry/sonitranslate:latest .
# VieNeu runs in /opt/vieneu-venv (tokenizers>=0.21); main env keeps tokenizers==0.15.2 for whisperX.
SONITR_VIENEU_PYTHON=/opt/vieneu-venv/bin/python
SONITR_RUNTIME_INSTALL=0
# Set to 1 to force reinstall on next start (overrides baked deps)
SONITR_FORCE_REINSTALL=0
